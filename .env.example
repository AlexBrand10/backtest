# Valores de desarrollo. Copia este archivo a .env (no se versiona).
# Los defaults del código ya coinciden con estos, así que también corre sin .env.

DJANGO_SECRET_KEY=dev-insecure-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

JWT_SECRET=cambia-esto-por-uno-largo-y-aleatorio
JWT_EXPIRATION_HOURS=8

DB_HOST=localhost
DB_PORT=5432
DB_NAME=prueba_tecnica
DB_USER=postgres
DB_PASSWORD=postgres
